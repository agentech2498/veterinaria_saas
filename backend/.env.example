# =============================================================================
#  VETERINARIA SAAS — Variables de entorno para desarrollo LOCAL
#  Copiar como .env en la raíz del proyecto
# =============================================================================

# ---------------------------------------------------------------------------
# BASE DE DATOS LOCAL (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/veterinaria_db

# O bien, por variables individuales (si no se define DATABASE_URL):
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=veterinaria_db

# ---------------------------------------------------------------------------
# SEGURIDAD
# ---------------------------------------------------------------------------
SECRET_KEY=local-dev-secret-cambiar-en-produccion-min32chars!!
SUPERADMIN_DEFAULT_PASSWORD=SuperAdmin123!@#

# ---------------------------------------------------------------------------
# REDIS (para caché de sesiones y mensajes del bot)
# Si no tenés Redis local, podés usar:
#   docker run -d -p 6379:6379 redis:alpine
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ---------------------------------------------------------------------------
# OPENAI (opcional para desarrollo, el bot fallará sin él)
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-...tu_clave_aqui...

# ---------------------------------------------------------------------------
# WHATSAPP / EVOLUTION API (opcional para desarrollo local)
# ---------------------------------------------------------------------------
# EVOLUTION_API_URL=https://tu-instancia.evolution-api.com
# EVOLUTION_API_KEY=tu_api_key
# EVOLUTION_INSTANCE=nombre_instancia

# ---------------------------------------------------------------------------
# STORAGE (Supabase Storage o local)
# Para desarrollo local podés dejar estas vacías y el storage fallará
# graciosamente (los PDFs no se guardarán remotamente pero los endpoints
# de generación sí funcionarán)
# ---------------------------------------------------------------------------
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=tu_service_role_key

# ---------------------------------------------------------------------------
# MERCADO PAGO (para el módulo de billing/suscripción)
# Usar credenciales de TEST en desarrollo
# ---------------------------------------------------------------------------
MP_ACCESS_TOKEN=TEST-xxxx-tu-token-de-prueba

# ---------------------------------------------------------------------------
# GOOGLE CALENDAR (opcional)
# ---------------------------------------------------------------------------
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
